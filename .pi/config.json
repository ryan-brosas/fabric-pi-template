{
  "profile": {
    "authority": "fabric-first"
  },
  "role_routes": {
    "build": {
      "model": "makora/zai-org/GLM-5.2-NVFP4",
      "thinking": "high",
      "contract": ".pi/agents/build.md"
    },
    "debug": {
      "model": "makora/zai-org/GLM-5.2-NVFP4",
      "thinking": "medium",
      "contract": ".pi/agents/debug.md",
      "tools": ["read", "grep", "find", "ls"]
    },
    "explore": {
      "model": "makora/zai-org/GLM-5.2-NVFP4",
      "thinking": "low",
      "contract": ".pi/agents/explore.md",
      "tools": ["read", "grep", "find", "ls"]
    },
    "general": {
      "model": "makora/zai-org/GLM-5.2-NVFP4",
      "thinking": "medium",
      "contract": ".pi/agents/general.md",
      "tools": ["read", "grep", "find", "ls", "edit", "write", "bash"]
    },
    "plan": {
      "model": "claude-bridge/claude-opus-4-8",
      "thinking": "medium",
      "contract": ".pi/agents/plan.md",
      "tools": ["read", "grep", "find", "ls"]
    },
    "review": {
      "model": "makora/zai-org/GLM-5.2-NVFP4",
      "thinking": "medium",
      "contract": ".pi/agents/review.md",
      "tools": ["read", "grep", "find", "ls"]
    },
    "scout": {
      "model": "makora/zai-org/GLM-5.2-NVFP4",
      "thinking": "low",
      "contract": ".pi/agents/scout.md",
      "tools": ["read", "grep", "find", "ls", "context7", "grepsearch", "codex_search"]
    },
    "vision": {
      "model": "makora/moonshotai/Kimi-K2.7-Code",
      "thinking": "medium",
      "contract": ".pi/agents/vision.md",
      "tools": ["read", "grep", "find", "ls"]
    }
  },
  "dispatch": {
    "default": "delegated",
    "max_parallel_workflow_agents": 8,
    "primary_integrates": true,
    "implementation_route": "general",
    "reasoning_never_implements": true,
    "implementation_models": ["makora/zai-org/GLM-5.2-NVFP4", "umans/umans-glm-5.2"],
    "implementation_pool": {
      "makora": 6,
      "umans": 2
    },
    "leaf_excluded_skills": {
      "skills": ["grill-me", "grill-with-docs"]
    },
    "skill_policy": {
      "required_skills_field": "required_skills",
      "every_brief_must_carry": true,
      "allow_empty": true,
      "unknown_skill_action": "reject: do not spawn",
      "role_defaults": "none; no skill loads implicitly"
    },
    "token_budgets": {
      "policy": "unlimited; 0 disables token ceilings",
      "implementation": 0,
      "review": 0,
      "research": 0
    },
    "retry_policy": {
      "max_retries_per_task": 1
    }
  },
  "coordination": {
    "mesh_topic_prefix": "fabric-pi-",
    "board_key_prefix": "fabric-pi/",
    "board_states": ["assigned", "running", "returned", "verified", "failed"],
    "poll_interval_ms": 60000
  },
  "actors": {
    "model": "makora/zai-org/GLM-5.2-NVFP4",
    "thinking": "medium",
    "tools": ["read", "grep", "find", "ls"],
    "default_topics": [],
    "contract": ".pi/agents/actor.md"
  },
  "permissions": {
    "enforced_by": ".pi/extensions/guard.ts",
    "policy": "deny secret-bearing paths and destructive, hook-bypass, or download-to-shell commands; confirm Git/npm external actions",
    "commit_message_format": "Conventional Commits: type(scope): subject"
  },
  "team_mode": {
    "phase_order": ["research", "plan", "implement", "verify", "review", "integrate", "goal"],
    "collaboration": {
      "board_retention": { "delete_finished": true }
    },
    "required_roles": {
      "research": {
        "routes": ["explore", "scout"],
        "minimum": 2,
        "require_successful_external_tool": true
      },
      "plan": {
        "routes": ["plan"],
        "minimum": 1
      },
      "implement": {
        "routes": ["general"],
        "minimum": 1,
        "maximum": 8
      },
      "verify": {
        "routes": ["review"],
        "minimum": 1
      },
      "review": {
        "routes": ["review"],
        "minimum": 1
      }
    },
    "research_evidence_tools": ["codex_search", "context7", "grepsearch"],
    "research_min_url_refs": 1,
    "review_payload_limit_chars": 800000
  }
}
