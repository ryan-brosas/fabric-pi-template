{
  "fullCodeMode": true,
  "approvals": {
    "read": "allow",
    "write": "allow",
    "execute": "allow",
    "network": "allow",
    "agent": "allow"
  },
  "executor": {
    "timeoutMs": 900000,
    "memoryLimitBytes": 4294967295,
    "maxOutputChars": 200000,
    "maxNestedResultChars": 500000,
    "resultFormat": "json"
  },
  "subagents": {
    "enabled": true,
    "runner": "pi",
    "transport": "auto",
    "thinking": "medium",
    "maxConcurrent": 8,
    "maxPerExecution": 32,
    "maxDepth": 1,
    "timeoutMs": 900000,
    "extensions": true,
    "defaultTools": ["read", "grep", "find", "ls"],
    "retainRuns": true,
    "notifyOnComplete": true,
    "budgetUsd": 0,
    "maxTokensPerChild": 0,
    "model": "makora/zai-org/GLM-5.2-NVFP4",
    "claude": {
      "model": "claude-bridge/claude-sonnet-5"
    }
  },
  "mesh": {
    "enabled": true,
    "actorScope": "project"
  },
  "memory": {
    "enabled": true
  },
  "capture": {
    "enabled": true,
    "hideFromModel": true,
    "keepVisible": ["fabric_exec"],
    "defaultRisk": "execute"
  },
  "mcp": {
    "enabled": true,
    "disableOAuth": true,
    "allowDynamicServers": false,
    "callTimeoutMs": 120000
  },
  "compaction": {
    "engine": "pi"
  }
}
