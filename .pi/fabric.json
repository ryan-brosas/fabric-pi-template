{
  "fullCodeMode": true,
  "schema": {
    "mode": "off"
  },
  "prewalk": {
    "model": "makora/zai-org/GLM-5.2-NVFP4"
  },
  "approvals": {
    "read": "allow",
    "write": "allow",
    "execute": "allow",
    "network": "allow",
    "agent": "allow"
  },
  "subagents": {
    "enabled": true,
    "runner": "pi",
    "extensions": false,
    "maxDepth": 1,
    "maxConcurrent": 32,
    "maxPerExecution": 16,
    "timeoutMs": 3600000,
    "defaultTools": [
      "read",
      "grep",
      "find",
      "ls"
    ],
    "budgetUsd": 0,
    "maxTokensPerChild": 0,
    "model": "openai-codex/gpt-5.6-sol",
    "thinking": "max",
    "claude": {
      "model": "claude/sonnet"
    },
    "transport": "process"
  },
  "mesh": {
    "actorScope": "session"
  },
  "memory": {
    "enabled": false,
    "indexToolOutput": false,
    "indexThinking": false
  },
  "compaction": {
    "engine": "fabric",
    "targetContextRatio": 0.7
  },
  "executor": {
    "runtime": "node-process",
    "memoryLimitBytes": 17179869184
  },
  "capture": {
    "keepVisible": [
      "fabric_exec",
      "context7_resolve-library-id",
      "context7_query-docs",
      "exa_web_search_exa",
      "exa_web_fetch_exa",
      "codex_search"
    ]
  }
}
